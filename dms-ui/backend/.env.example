# ============================================================
# Liberation Bot — DMS Web UI Backend
# Copy to .env and fill in your values.
# ============================================================

# Path to the SAME SQLite database file the bot uses.
# The UI backend opens it read/write alongside the bot.
DATABASE_PATH=../../data/liberation_bot.db

# JWT secret for DMS session tokens (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
DMS_JWT_SECRET=change-me-to-a-random-64-char-string

# Session duration in hours (default: 8)
DMS_SESSION_HOURS=8

# Bot's Matrix homeserver URL — used to send OTP DMs
MATRIX_HOMESERVER_URL=https://your.homeserver.org

# Bot access token — used to send OTP DMs
# Get this from the bot's session after first login, or set MATRIX_BOT_PASSWORD below
MATRIX_BOT_ACCESS_TOKEN=

# Bot Matrix user ID
MATRIX_BOT_USER_ID=@liberation-bot:your.homeserver.org

# Bot password (used if access token is not set, to obtain a token on startup)
MATRIX_BOT_PASSWORD=

# CORS origins for the frontend (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server bind settings
HOST=0.0.0.0
PORT=8001
