# ============================================================
# Liberation Bot — Environment Configuration (Phase II)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Matrix Bot Account ---
# The full Matrix user ID for the bot account (e.g., @liberation-bot:matrix.org)
MATRIX_BOT_USER_ID=@liberation-bot:your.homeserver.org

# The bot account password
MATRIX_BOT_PASSWORD=your_secure_bot_password_here

# The Matrix homeserver URL (e.g., https://matrix.org)
MATRIX_HOMESERVER_URL=https://your.homeserver.org

# The Matrix room ID for the monitored group (e.g., !roomid:matrix.org)
MATRIX_GROUP_ROOM_ID=!your_room_id:your.homeserver.org

# The bot's display name in Matrix (used for @mention detection)
BOT_DISPLAY_NAME=liberation-bot

# --- Database ---
# Path to the SQLite database file
DATABASE_PATH=./data/liberation_bot.db

# --- Encryption (Dead Man's Switch) ---
# Master key for AES-256-GCM encryption of emergency vault data.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
BOT_MASTER_KEY=generate_a_64_char_hex_string_here

# --- Web Search (Tiered: DDG → Serper → Tavily) ---
# Tier 1: DuckDuckGo is FREE and requires no API key.
# The bot will always try DDG first.
#
# Tier 2: Serper.dev (~$0.001/query). Optional fallback when DDG is rate-limited.
# Get a key at: https://serper.dev
SERPER_API_KEY=

# Tier 3: Tavily (~$0.01/query). Optional fallback when Serper also fails.
# Get a key at: https://tavily.com
TAVILY_API_KEY=

# Maximum results per web search query (default: 5)
WEB_SEARCH_MAX_RESULTS=5

# Minimum seconds between DuckDuckGo calls to avoid rate-limiting (default: 2.0)
DDG_THROTTLE_SECONDS=2.0

# --- Bot Behavior ---
# Number of group members required to activate the switch (default: 3)
CONSENSUS_THRESHOLD=3

# Default missing threshold in hours if user does not specify (default: 72)
DEFAULT_MISSING_THRESHOLD_HOURS=72

# How often (in minutes) the heartbeat checker runs (default: 60)
HEARTBEAT_CHECK_INTERVAL_MINUTES=60

# How many days of chat history to retain in the database (default: 90)
CHAT_HISTORY_RETENTION_DAYS=90

# --- Agentic AI Core (Kimi K2 via NVIDIA NIM) ---
# Your NVIDIA NIM API key. Get a free key at: https://build.nvidia.com/settings/api-keys
# The model used is: moonshotai/kimi-k2-instruct
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# Maximum tokens for the agent's response (default: 1024)
AGENT_MAX_RESPONSE_TOKENS=1024

# Number of recent chat messages to include in the agent's context window (default: 30)
AGENT_CONTEXT_WINDOW_MESSAGES=30

# --- Agent Rate Limiting ---
# Three-layer defence against NVIDIA API exhaustion:
#
# Layer 1 — Global concurrency semaphore.
# Maximum number of simultaneous Kimi K2 API calls across ALL users and agents
# (main @bot agent + video dialogue agent share the same semaphore).
# Default: 1 (serialise all calls). Raise to 2-3 if NVIDIA grants a higher tier.
AGENT_MAX_CONCURRENT_CALLS=1

# Layer 2 — Per-user cooldown (enforced in bot.py before calling the agent).
# Minimum seconds a user must wait between @bot queries.
# Queries within this window are rejected with a polite message.
# Set to 0 to disable (not recommended on free-tier keys).
AGENT_USER_COOLDOWN_S=30

# Layer 3 — 429 retry-with-backoff (enforced inside AgentCore and VideoDialogueAgent).
# Maximum number of retry attempts on HTTP 429 RateLimitError.
AGENT_MAX_RETRIES=3

# Base delay in seconds for the first retry. Subsequent retries use
# exponential backoff: base * 2^attempt, capped at AGENT_RETRY_MAX_DELAY_S.
AGENT_RETRY_BASE_DELAY_S=5.0

# Maximum delay in seconds between retries regardless of backoff calculation.
AGENT_RETRY_MAX_DELAY_S=60.0

# --- Video Planning Room ---
# Matrix room ID for the "Video Planning and Generation" room.
# Get this from the room settings in your Matrix client (Advanced → Internal Room ID).
# Leave blank to disable the video planning workflow.
MATRIX_VIDEO_ROOM_ID=!your_video_room_id:your.homeserver.org

# Directory where generated videos will be saved on the server.
# Ensure the bot process has write access to this path.
VIDEO_OUTPUT_DIR=./data/videos

# --- Liberation Archives (NotebookLM) ---
# The Google NotebookLM notebook ID for the Liberation Archives.
# This is the notebook containing Havana Syndrome / Neurowarfare research.
# Find the ID in the notebook URL: https://notebooklm.google.com/notebook/<NOTEBOOK_ID>
LIBERATION_ARCHIVES_NOTEBOOK_ID=your_notebooklm_notebook_id_here

# Timeout in seconds for NotebookLM queries / video generation (default: 60 for queries, 1800 for video)
NOTEBOOKLM_TIMEOUT_SECS=60

# Timeout in seconds for video generation (default: 1800 = 30 min; cinematic may need 2400+)
NOTEBOOKLM_VIDEO_TIMEOUT_SECS=1800

# NotebookLM authentication — provide ONE of the following:
#
# Option A (recommended for servers): Inline JSON from your storage_state.json
# Run `notebooklm login` on a machine with a browser, then copy the contents of
# ~/.notebooklm/storage_state.json here as a single-line JSON string.
NOTEBOOKLM_AUTH_JSON=

# Option B: Path to directory containing storage_state.json
# NOTEBOOKLM_HOME=/home/youruser/.notebooklm

# --- FOIA Lifecycle ---
# How often (in minutes) the FOIA deadline monitor checks for overdue requests.
# The monitor sends a proactive DM reminder when a deadline is approaching or passed.
# Default: 360 (6 hours). Set to 0 to disable.
FOIA_DEADLINE_CHECK_INTERVAL_MINUTES=360

# Comma-separated list of topics to monitor via web search.
# Leave blank to use the built-in defaults (Havana Syndrome, AHI, Neurowarfare).
# Example: "CIA AHI investigation 2025,directed energy weapons civilian,FOIA appeal ruling"
FOIA_WATCHED_TOPICS=

# How often (in minutes) the watched topic scanner runs.
# Default: 720 (12 hours). Set to 0 to disable.
WATCHED_TOPIC_SCAN_INTERVAL_MINUTES=720

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/bot.log
