# ============================================================
# Matrix Wellness Bot - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Matrix Bot Account ---
# The full Matrix user ID for the bot account (e.g., @wellness-bot:matrix.org)
MATRIX_BOT_USER_ID=@wellness-bot:your.homeserver.org

# The bot account password
MATRIX_BOT_PASSWORD=your_secure_bot_password_here

# The Matrix homeserver URL (e.g., https://matrix.org)
MATRIX_HOMESERVER_URL=https://your.homeserver.org

# The Matrix room ID for the monitored group (e.g., !roomid:matrix.org)
MATRIX_GROUP_ROOM_ID=!your_room_id:your.homeserver.org

# --- Database ---
# Path to the SQLite database file (or PostgreSQL DSN for production)
DATABASE_PATH=./data/wellness_bot.db

# --- Encryption ---
# Master key for the bot's own data-at-rest encryption (AES-256-GCM).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
BOT_MASTER_KEY=generate_a_64_char_hex_string_here

# --- OSINT / Search API ---
# SerpAPI key for Google search (obituaries, news). Get one at https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# --- Bot Behavior ---
# Number of group members required to activate the switch (default: 3)
CONSENSUS_THRESHOLD=3

# Default missing threshold in hours if user does not specify (default: 72)
DEFAULT_MISSING_THRESHOLD_HOURS=72

# How often (in minutes) the heartbeat checker runs (default: 60)
HEARTBEAT_CHECK_INTERVAL_MINUTES=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/bot.log
